// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Cliente {
  id                  String      @id @default(uuid())
  nome                String
  meta_ads_account_id String
  insights            String?     @default("")
  campanhas           Campanha[]
  relatorios          Relatorio[]
  leads               Lead[]
  criado_em           DateTime    @default(now())
}

model Lead {
  id          String   @id @default(uuid())
  cliente_id  String
  cliente     Cliente  @relation(fields: [cliente_id], references: [id])
  nome        String
  contato     String?
  status      String   @default("NOVO") // NOVO, CONTATO, NEGOCIACAO, FECHADO, PERDIDO
  valor       Decimal  @default(0.0)
  origem      String?
  data        DateTime @default(now())
  criado_em   DateTime @default(now())
}

model Usuario {
  id        String   @id @default(uuid())
  nome      String
  role      String   @default("analista") // admin ou analista
  criado_em DateTime @default(now())
}

model Campanha {
  id             String            @id @default(uuid())
  cliente_id     String
  cliente        Cliente           @relation(fields: [cliente_id], references: [id])
  nome_gerado    String // Ex: [03][KrM][CBO][Message]
  meta_id        String            @unique
  objetivo       String
  tipo_orcamento String
  conjuntos      ConjuntoAnuncio[]
  metricas       MetricaCampanha[]
  criativos      Criativo[]
  criado_em      DateTime          @default(now())
}

model ConjuntoAnuncio {
  id            String     @id @default(uuid())
  campanha_id   String
  campanha      Campanha   @relation(fields: [campanha_id], references: [id])
  nome_gerado   String // Ex: [03][KrM][LAL 1%][Feed]
  publico_alvo  String
  formato_midia String
  criativos     Criativo[]
}

model Criativo {
  id              String          @id @default(uuid())
  adset_id        String?
  conjunto        ConjuntoAnuncio? @relation(fields: [adset_id], references: [id])
  campanha_id     String?
  campanha        Campanha?        @relation(fields: [campanha_id], references: [id])
  
  meta_ad_id      String?         @unique
  nome_anuncio    String?
  url_midia       String? // Link da miniatura/imagem da Meta
  texto_principal String? // Copy gerada
  call_to_action  String?
  
  metricas        MetricaCriativo[]
  criado_em       DateTime          @default(now())
}

model MetricaCriativo {
  id              String   @id @default(uuid())
  criativo_id     String
  criativo        Criativo @relation(fields: [criativo_id], references: [id])
  data            DateTime
  impressoes      Int      @default(0)
  alcance         Int      @default(0)
  cliques         Int      @default(0)
  valor_investido Decimal  @default(0.0)
  leads           Int      @default(0)
  compras         Int      @default(0)
  ctr             Decimal?

  @@unique([criativo_id, data])
}

model MetricaCampanha {
  id                 String   @id @default(uuid())
  campanha_id        String
  campanha           Campanha @relation(fields: [campanha_id], references: [id])
  data               DateTime
  impressoes         Int      @default(0)
  alcance            Int      @default(0)
  cliques            Int      @default(0)
  visitas_perfil     Int      @default(0)
  seguidores         Int      @default(0)
  conversas_leads    Int      @default(0)
  valor_investido    Decimal  @default(0.0)
  faturamento_manual Decimal? @default(0.0) // Inserido no painel
  cac                Decimal?
  roas               Decimal?
  compras            Int      @default(0)
  valor_compras      Decimal? @default(0.0)

  @@unique([campanha_id, data])
}

model Relatorio {
  id                        String   @id @default(uuid())
  cliente_id                String
  cliente                   Cliente  @relation(fields: [cliente_id], references: [id])
  url_pdf                   String?
  diagnostico_performance   String? // Gerado pelo Gemini
  desenvolvimento_algoritmo String? // Gerado pelo Gemini
  proximos_passos           String? // Gerado pelo Gemini
  criado_em                 DateTime @default(now())
}
