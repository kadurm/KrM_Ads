// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Cliente {
  id                  String      @id @default(uuid())
  nome                String
  slug                String?     @unique // Ex: solutionplace
  meta_ads_account_id String
  meta_access_token   String?     @default("")
  meta_pixel_id       String?     @default("")
  setor               String?     @default("Geral")
  insights            String?     @default("")
  whatsapp_instance_url   String? @default("")
  whatsapp_instance_name  String? @default("")
  whatsapp_instance_token String? @default("")
  campanhas           Campanha[]
  relatorios          Relatorio[]
  leads               Lead[]
  historico_contexto  HistoricoContexto[]
  metodos_pagamento   MetodoPagamento[]
  transacoes          Transacao[]
  notas_fiscais       NotaFiscal[]
  metricas_conta      MetricaContaDiaria[]
  criado_em           DateTime    @default(now())
}

model HistoricoContexto {
  id         String   @id @default(uuid())
  cliente_id String
  cliente    Cliente  @relation(fields: [cliente_id], references: [id], onDelete: Cascade)
  conteudo   String
  criado_em  DateTime @default(now())
}

model Lead {
  id          String   @id @default(uuid())
  cliente_id  String
  cliente     Cliente  @relation(fields: [cliente_id], references: [id])
  nome        String
  contato     String?
  status      String   @default("NOVO") // NOVO, CONTATO, NEGOCIACAO, FECHADO, PERDIDO
  valor       Decimal  @default(0.0)
  origem      String?
  notas       Nota[]
  agendamentos Agendamento[]
  data        DateTime @default(now())
  criado_em   DateTime @default(now())
}

model Nota {
  id        String   @id @default(uuid())
  lead_id   String
  lead      Lead     @relation(fields: [lead_id], references: [id])
  texto     String
  autor     String?  // Nome do funcionário
  criado_em DateTime @default(now())
}

model Agendamento {
  id         String   @id @default(uuid())
  lead_id    String
  lead       Lead     @relation(fields: [lead_id], references: [id], onDelete: Cascade)
  tipo       String   // ex: "PRONTA_ENTREGA" ou "BLINDAGEM"
  data_hora  DateTime
  status     String   @default("AGENDADO") // AGENDADO, REALIZADO, CANCELADO
  observacao String?  @db.Text
  criado_em  DateTime @default(now())
}

model Usuario {
  id        String   @id @default(uuid())
  nome      String
  role      String   @default("analista") // admin ou analista
  criado_em DateTime @default(now())
}

model Campanha {
  id             String            @id @default(uuid())
  cliente_id     String
  cliente        Cliente           @relation(fields: [cliente_id], references: [id])
  nome_gerado    String // Ex: [03][KrM][CBO][Message]
  meta_id        String            @unique
  objetivo       String
  tipo_orcamento String
  conjuntos      ConjuntoAnuncio[]
  metricas       MetricaCampanha[]
  criativos      Criativo[]
  criado_em      DateTime          @default(now())

  @@index([cliente_id])
}

model ConjuntoAnuncio {
  id            String     @id @default(uuid())
  campanha_id   String
  campanha      Campanha   @relation(fields: [campanha_id], references: [id])
  nome_gerado   String // Ex: [03][KrM][LAL 1%][Feed]
  publico_alvo  String
  formato_midia String
  criativos     Criativo[]
}

model Criativo {
  id              String          @id @default(uuid())
  adset_id        String?
  conjunto        ConjuntoAnuncio? @relation(fields: [adset_id], references: [id])
  campanha_id     String?
  campanha        Campanha?        @relation(fields: [campanha_id], references: [id])
  
  meta_ad_id      String?         @unique
  nome_anuncio    String?
  url_midia       String? // Link da miniatura/imagem da Meta
  texto_principal String? // Copy gerada
  call_to_action  String?
  
  metricas        MetricaCriativo[]
  criado_em       DateTime          @default(now())

  @@index([campanha_id])
  @@index([adset_id])
}

model MetricaCriativo {
  id              String   @id @default(uuid())
  criativo_id     String
  criativo        Criativo @relation(fields: [criativo_id], references: [id])
  data            DateTime
  impressoes      Int      @default(0)
  alcance         Int      @default(0)
  cliques         Int      @default(0)
  valor_investido Decimal  @default(0.0)
  leads           Int      @default(0)
  compras         Int      @default(0)
  reacoes_sociais Int      @default(0)
  ctr             Decimal?

  @@unique([criativo_id, data])
  @@index([data(sort: Desc)])
}

model MetricaCampanha {
  id                 String   @id @default(uuid())
  campanha_id        String
  campanha           Campanha @relation(fields: [campanha_id], references: [id])
  data               DateTime
  impressoes         Int      @default(0)
  alcance            Int      @default(0)
  cliques            Int      @default(0)
  visitas_perfil     Int      @default(0)
  seguidores         Int      @default(0)
  conversas_leads    Int      @default(0)
  reacoes_sociais    Int      @default(0) // Likes, comentários, salvamentos, shares
  valor_investido    Decimal  @default(0.0)
  faturamento_manual Decimal? @default(0.0) // Inserido no painel
  cac                Decimal?
  roas               Decimal?
  compras            Int      @default(0)
  valor_compras      Decimal? @default(0.0)

  @@unique([campanha_id, data])
  @@index([data(sort: Desc)])
}

model Relatorio {
  id                        String   @id @default(uuid())
  cliente_id                String
  cliente                   Cliente  @relation(fields: [cliente_id], references: [id])
  url_pdf                   String?
  diagnostico_performance   String? // Gerado pelo Gemini
  desenvolvimento_algoritmo String? // Gerado pelo Gemini
  proximos_passos           String? // Gerado pelo Gemini
  criado_em                 DateTime @default(now())
}

model MetodoPagamento {
  id           String      @id @default(uuid())
  cliente_id   String
  cliente      Cliente     @relation(fields: [cliente_id], references: [id], onDelete: Cascade)
  tipo         String      // PIX, BOLETO, CARTAO, TRANSFERENCIA
  descricao    String      // "PIX CPF ***123", "Cartão final 4242"
  chave_pix    String?     // Chave PIX (se tipo = PIX)
  dados_banco  String?     // JSON com dados bancários (se transferência)
  is_principal Boolean     @default(false)
  ativo        Boolean     @default(true)
  transacoes   Transacao[]
  criado_em    DateTime    @default(now())
}

model Transacao {
  id                  String            @id @default(uuid())
  cliente_id          String
  cliente             Cliente           @relation(fields: [cliente_id], references: [id], onDelete: Cascade)
  metodo_pagamento_id String?
  metodo              MetodoPagamento?  @relation(fields: [metodo_pagamento_id], references: [id])
  tipo                String            // COBRANCA, PAGAMENTO, REEMBOLSO
  categoria           String            @default("ADS") // ADS, HONORARIO, SERVICO
  descricao           String
  valor               Decimal
  status              String            @default("PENDENTE") // PENDENTE, PAGO, VENCIDO, CANCELADO
  data_vencimento     DateTime?
  data_pagamento      DateTime?
  referencia          String?           // Código de barras, link PIX, etc.
  nota_fiscal         NotaFiscal?
  criado_em           DateTime          @default(now())
}

model NotaFiscal {
  id           String   @id @default(uuid())
  cliente_id   String
  cliente      Cliente  @relation(fields: [cliente_id], references: [id], onDelete: Cascade)
  transacao_id String?  @unique
  transacao    Transacao? @relation(fields: [transacao_id], references: [id])
  numero       Int
  valor        Decimal
  descricao    String
  status       String   @default("EMITIDA") // EMITIDA, CANCELADA
  url_pdf      String?
  criado_em    DateTime @default(now())
}

model MetricaContaDiaria {
  id              String   @id @default(uuid())
  cliente_id      String
  cliente         Cliente  @relation(fields: [cliente_id], references: [id], onDelete: Cascade)
  data            DateTime
  followers_count Int      @default(0)

  @@unique([cliente_id, data])
  @@index([data(sort: Desc)])
}

model LeadSolution {
  id                String    @id @default(uuid())
  telefone          String
  data              DateTime?
  nome_cliente      String?
  origem            String?
  primeira_mensagem String?
  tipo_servico      String?
  veiculo           String?
  comercial         String?
  conversao         String?
  status            String?
  valor_faturado    Decimal?  @default(0.0)
  criado_em         DateTime  @default(now())
  atualizado_em     DateTime  @updatedAt

  @@unique([telefone])
}


